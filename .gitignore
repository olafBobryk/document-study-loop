!exam-revision/source/.gitkeep
*.pdf
*.ppt
*.pptx
*.key
*.zip
*.7z
*.rar
*.doc
*.docx
*.xls
*.xlsx

# Local/private workspaces
local-private/
local-source/

# Local/editor state
.vscode/
.idea/

# Secrets/local env
.env
.env.*
!.env.example

# Generated caches
node_modules/
__pycache__/
.cache/
tmp/
